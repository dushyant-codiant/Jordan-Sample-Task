{% schema %}
{
  "name": "Centered Text Block",
  "tag": "section",
  "class": "centered-text-block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our Journey Begins"
    },
    {
      "type": "textarea",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "This is a customizable text block where you can describe your brand’s mission, story, or product values. Use this space to make a connection with your customers."
    },
    {
      "type": "textarea",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Feel free to add more information here — whether it's about your products, services, or inspiration. Keep it brief and engaging."
    }
  ],
  "presets": [
    {
      "name": "Centered Text Block",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<section class="centered-text-block-section">
  <div class="centered-text-block-wrapper">
    <h1 class="ctb-heading">{{ section.settings.heading }}</h1>
    <h2 class="ctb-subheading">{{ section.settings.subheading }}</h2>
    <p class="ctb-paragraph">{{ section.settings.paragraph_1 }}</p>
    <p class="ctb-paragraph ctb-note">{{ section.settings.paragraph_2 }}</p>
  </div>
</section>

<style>
  .centered-text-block-section {
    padding: 80px 20px;
    background: linear-gradient(to bottom right, #f8faf9, #ffffff);
    text-align: center;
    color: #2e2e2e;
    animation: fadeInUp 0.7s ease-out both;
  }

  .centered-text-block-wrapper {
    max-width: 800px;
    margin: 0 auto;
  }

  .ctb-heading {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 20px;
    color: #1a3e2d;
    font-family: 'Georgia', serif;
  }

  .ctb-subheading {
    font-size: 1.75rem;
    font-weight: 500;
    margin-bottom: 25px;
    color: #4c7c5b;
    font-family: 'Helvetica Neue', sans-serif;
  }

  .ctb-paragraph {
    font-size: 1.125rem;
    line-height: 1.75;
    color: #555;
    margin-bottom: 20px;
    font-family: 'Helvetica Neue', sans-serif;
  }

  .ctb-note {
    font-style: italic;
    color: #3a5f3e;
  }

  @media (max-width: 768px) {
    .ctb-heading {
      font-size: 2.2rem;
    }

    .ctb-subheading {
      font-size: 1.4rem;
    }

    .ctb-paragraph {
      font-size: 1rem;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
